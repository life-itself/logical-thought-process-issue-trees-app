{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/project-ltp/ltp-model.schema.json",
  "title": "Project LTP shared causal model",
  "type": "object",
  "required": ["project", "entities", "links", "views"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "analyzed_path": { "type": "string" },
        "analysis_mode": { "enum": ["forward", "reverse", "reconciliation"] },
        "provisional_goal": { "type": "string" }
      },
      "additionalProperties": true
    },
    "analysis": {
      "type": "object",
      "properties": {
        "current_constraint": { "type": "string" },
        "recommended_next_action": { "type": "string" },
        "expected_effect": { "type": "string" },
        "updated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "statement", "status", "confidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "status": {
            "enum": ["observed", "inferred", "provisional", "confirmed", "disputed"]
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "assumptions": { "type": "array", "items": { "type": "string" } },
          "reasoning": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "relation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "relation": { "type": "string", "minLength": 1 },
          "logic": { "type": "string" },
          "assumption": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "observation"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "lines": { "type": ["string", "number"] },
          "observation": { "type": "string" },
          "interpretation": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "views": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "goal-tree",
          "current-reality",
          "evaporating-cloud",
          "future-reality",
          "prerequisite-tree",
          "transition-tree"
        ]
      },
      "additionalProperties": {
        "type": "object",
        "required": ["entities", "links"],
        "properties": {
          "title": { "type": "string" },
          "purpose": { "type": "string" },
          "entities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "links": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        },
        "additionalProperties": false
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "contradictions": { "type": "array", "items": { "type": "string" } },
    "coverage_gaps": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
